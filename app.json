{
  "expo": {
    "name": "POPU",
    "slug": "shopify-popu-app",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/images/popu_logo.png",
    "scheme": "shopifypopuapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.raredoge.shopify-popu-app",
      "buildNumber": "6",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/popu_logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.raredoge.shopifypopuapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/popu_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/popu_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 23
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Popu Micro Beauty requires access to your photo library so you can choose existing photos of yourself to preview custom eyebrow and cosmetic designs.",
          "cameraPermission": "Popu Micro Beauty requires camera access so you can take photos of yourself to preview custom eyebrow and cosmetic designs."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Popu Micro Beauty requires access to your photo library so you can choose existing photos to preview custom eyebrow designs.",
          "savePhotosPermission": "Popu Micro Beauty requires permission to save your customized eyebrow design previews to your photo library."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f156a1c0-c7d5-482b-be04-f61c2d596e54"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f156a1c0-c7d5-482b-be04-f61c2d596e54"
    }
  }
}